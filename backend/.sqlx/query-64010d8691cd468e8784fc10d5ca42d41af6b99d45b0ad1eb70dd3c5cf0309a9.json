  "query": "\n        SELECT q.price, q.change_abs, q.change_pct\n        FROM intelligence.quotes q\n        JOIN intelligence.assets a ON a.id = q.asset_id\n        WHERE a.symbol = $1\n        ORDER BY q.ts DESC\n        LIMIT 1\n        ",
