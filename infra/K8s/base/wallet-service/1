apiVersion: apps/v1
kind: Deployment
metadata:
  name: wallet-service
  namespace: trading-platform
spec:
  replicas: 2
  selector:
    matchLabels:
      app: wallet-service
  template:
    metadata:
      labels:
        app: wallet-service
    spec:
      containers:
        - name: wallet-service
          image: europe-west2-docker.pkg.dev/globalquantx-prod/wallet/wallet-service:v0.0.1
          env:
            - name: DATABASE_URL
              valueFrom:
                secretKeyRef:
                  name: wallet-db-url
                  key: DATABASE_URL
            - name: NATS_URL
              value: nats://nats:4222
          ports:
            - containerPort: 8080


          volumeMounts:
            - name: cockroachdb-ca
              mountPath: /app/root.crt
              subPath: root.crt
      volumes:
        - name: cockroachdb-ca
          secret:
            secretName: wallet-db-url
            items:
              - key: ca.crt
                path: root.crt
