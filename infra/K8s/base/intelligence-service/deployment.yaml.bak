apiVersion: apps/v1
kind: Deployment
metadata:
  name: intelligence-service
  namespace: trading-platform
  labels:
    app: intelligence-service
spec:
  replicas: 2
  selector:
    matchLabels:
      app: intelligence-service
  template:
    metadata:
      labels:
        app: intelligence-service
    spec:
      containers:
        - name: intelligence-service
          image: europe-west2-docker.pkg.dev/globalquantx-prod/api/intelligence-service:v0.0.1
          imagePullPolicy: Always

          env:
            - name: DATABASE_URL
              value: "postgresql://root@cockroachdb-public:26257/globalquantx?sslmode=disable"

            - name: NATS_URL
              value: "nats://nats:4222"

            - name: INTELLIGENCE_API_KEY
              valueFrom:
                secretKeyRef:
                  name: intelligence-service-secret
                  key: api_key

            - name: RUST_LOG
              value: info

          ports:
            - containerPort: 8080

          readinessProbe:
            httpGet:
              path: /ready
              port: 8080
            initialDelaySeconds: 3
            periodSeconds: 5

          livenessProbe:
            httpGet:
              path: /live
              port: 8080
            initialDelaySeconds: 5
            periodSeconds: 10

