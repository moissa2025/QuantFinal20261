apiVersion: apps/v1
kind: Deployment
metadata:
  name: api-gateway
  namespace: trading-platform
  labels:
    app: api-gateway
spec:
  replicas: 1
  selector:
    matchLabels:
      app: api-gateway
  template:
    metadata:
      labels:
        app: api-gateway
    spec:
      containers:
        - name: api-gateway
          image: europe-west2-docker.pkg.dev/globalquantx-prod/api/api-gateway:v0.0.1
          imagePullPolicy: Always

          env:
            - name: DATABASE_URL
              value: "postgresql://root@cockroachdb-public:26257/globalquantx?sslmode=disable"

            - name: NATS_URL
              value: "nats://nats:4222"

            - name: RUST_LOG
              value: info

          ports:
            - containerPort: 8080

          readinessProbe:
            httpGet:
              path: /health
              port: 8080
            initialDelaySeconds: 3
            periodSeconds: 5

          livenessProbe:
            httpGet:
              path: /health
              port: 8080
            initialDelaySeconds: 5
            periodSeconds: 10

