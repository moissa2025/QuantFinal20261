apiVersion: apps/v1
kind: Deployment
metadata:
  name: auth-service
  namespace: trading-platform
  labels:
    app: auth-service
spec:
  replicas: 2
  selector:
    matchLabels:
      app: auth-service
  template:
    metadata:
      labels:
        app: auth-service
    spec:
      containers:
        - name: auth-service
          image: europe-west2-docker.pkg.dev/globalquantx-prod/api/auth-service:v0.0.9
          imagePullPolicy: Always

          env:
            - name: DATABASE_URL
              value: "postgresql://root@cockroachdb-public:26257/globalquantx?sslmode=disable"

            - name: NATS_URL
              value: "nats://nats:4222"

            - name: REFRESH_TOKEN_KEY
              valueFrom:
                secretKeyRef:
                  name: auth-refresh-key
                  key: REFRESH_TOKEN_KEY

            - name: RUST_LOG
              value: info

          ports:
            - containerPort: 9001

          readinessProbe:
            httpGet:
              path: /ready
              port: 9001
            initialDelaySeconds: 3
            periodSeconds: 5

          livenessProbe:
            httpGet:
              path: /live
              port: 9001
            initialDelaySeconds: 5
            periodSeconds: 10

